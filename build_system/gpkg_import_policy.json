{
  "skip_dependency_patterns": [
    "debconf-2.0"
  ],
  "skip_packages": [
    "apt",
    "base-files",
    "base-passwd",
    "bash",
    "debianutils",
    "dpkg",
    "glibc-*",
    "grub*",
    "init",
    "initramfs-tools*",
    "libc6",
    "libpam-systemd",
    "linux-image-*",
    "mount",
    "openssh-server",
    "passwd",
    "sysvinit*",
    "udev",
    "util-linux"
  ],
  "dependency_choices": {
    "debconf | debconf-2.0": "debconf",
    "libgtk-3-0::dconf-gsettings-backend | gsettings-backend": "dconf-gsettings-backend",
    "libpam-systemd | logind": "logind",
    "policykit-1-gnome | polkit-1-auth-agent": "polkit-1-auth-agent"
  },
  "dependency_rewrites": {
    "libpam-systemd": "libpam-elogind",
    "systemd": "elogind"
  },
  "provider_choices": {
    "logind": "libpam-elogind",
    "polkit-1-auth-agent": "mate-polkit"
  },
  "package_overrides": {
    "gpg-from-sq": {
      "replaces_add": [
        "gpg"
      ],
      "conflicts_add": [
        "gpg"
      ]
    },
    "nano": {
      "section": "editors"
    },
    "python3-pip": {
      "include_recommends": false
    },
    "tasksel": {
      "depends_remove": [
        "apt"
      ]
    },
    "xfce4-terminal": {
      "depends_add": [
        "hicolor-icon-theme"
      ],
      "drop_scripts": [
        "postinst"
      ]
    }
  }
}
