# Paths are resolved by the shell or systemd before the publisher starts.
# PACKAGE_ROOTS accepts a colon-separated list of directories to scan recursively.
PACKAGE_ROOTS=/srv/geminios/packages
WORK_ROOT=/srv/gpkg-publisher/work
PUBLISH_ROOT=/srv/gpkg-publisher/repo

# Commands installed from https://github.com/CreitinGameplays/geminios-sdk
GPKG_BUILD_BIN=gpkg-build
GPKG_SCANREPO_BIN=gpkg-scanrepo

# Tune this down if package build hooks share mutable build state.
BUILD_JOBS=4
RUN_BUILD_HOOKS=true
KEEP_FAILED_RUN=true

# Set to false if you only want to build a local repository mirror.
PUBLISH_ENABLED=true

# Supported values: rclone, none
UPLOAD_BACKEND=rclone

# Example Backblaze B2 destination:
# RCLONE_REMOTE=geminios-b2:geminios-packages/repo
# Example Cloudflare R2 destination:
# RCLONE_REMOTE=geminios-r2:geminios-packages/repo
RCLONE_REMOTE=

# Optional extra flags passed to `rclone sync`.
RCLONE_EXTRA_ARGS=--fast-list --s3-no-check-bucket
