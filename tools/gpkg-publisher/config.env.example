# GeminiOS GPKG bulk publisher configuration
# Copy this file to /etc/gpkg-publisher/config.env and adjust paths.

ARCH=x86_64
APT_ARCH=amd64

# seeds = use SEED_FILE
# all = discover packages from apt-cache dumpavail
DISCOVERY_MODE=seeds

REPO_ROOT=/var/lib/gpkg-publisher/repo
DOWNLOAD_DIR=/var/lib/gpkg-publisher/cache/debs
STATE_FILE=/var/lib/gpkg-publisher/state/state.json
REPORT_FILE=/var/lib/gpkg-publisher/state/last-run.json

SEED_FILE=/etc/gpkg-publisher/packages.txt
OVERRIDES_FILE=/etc/gpkg-publisher/overrides.json

# Used only when DISCOVERY_MODE=all.
SECTION_ALLOWLIST=
SECTION_BLOCKLIST=debug,doc,devel,kernel,libdevel,metapackages,oldlibs
PRIORITY_BLOCKLIST=required,important

# 0 means no limit.
PACKAGE_LIMIT=0

# Lower than the SDK default on purpose so mass imports complete faster.
ZSTD_LEVEL=10
INDEX_ZSTD_LEVEL=19

# Default safety stance.
INCLUDE_MAINTAINER_SCRIPTS=0
ALLOW_ESSENTIAL=0

# Uploads are enabled by default. Set to 0 if you only want local staging.
UPLOAD_ENABLED=1

# Preferred Cloudflare R2 path when using rclone.
# Example: r2:my-bucket/geminios
RCLONE_DEST=

# Optional extra rclone flags.
# Example: --s3-no-check-bucket
RCLONE_EXTRA_ARGS=

# Optional full override. If set, this is used instead of RCLONE_DEST.
# Available placeholders: {repo_root} and {arch_dir}
UPLOAD_COMMAND=

# Extra package globs to block in addition to the built-in defaults.
BLOCKLIST_PATTERNS=base-files,base-passwd,bash,debianutils,dpkg,gcc-*,glibc-*,grub*,init,initramfs-tools*,linux-*,libc6,libpam*,libsystemd*,mount,openssh-server,passwd,systemd*,sysvinit*,udev,util-linux
