{
  "skip_packages": [
    "systemd",
    "udev",
    "linux-image-*"
  ],
  "skip_patterns": [
    "initramfs-tools*"
  ],
  "skip_dependency_patterns": [
    "debconf-2.0"
  ],
  "provided_by_system_patterns": [
    "debianutils",
    "init-system-helpers",
    "libc6",
    "libcrypt1",
    "libgcc-s1",
    "libstdc++6",
    "lsb-base",
    "perl-base",
    "python3-minimal",
    "sysvinit-utils"
  ],
  "dependency_choices": {
    "debconf | debconf-2.0": "debconf",
    "libgtk-3-0::dconf-gsettings-backend | gsettings-backend": "dconf-gsettings-backend",
    "lightdm::libpam-systemd | logind": "logind"
  },
  "provider_choices": {
    "logind": "libpam-elogind"
  },
  "package_overrides": {
    "nano": {
      "section": "editors"
    },
    "xfce4-terminal": {
      "depends_add": [
        "hicolor-icon-theme"
      ],
      "drop_scripts": [
        "postinst"
      ]
    },
    "some-problem-package": {
      "skip": true
    }
  }
}
